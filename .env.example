APP_NAME=individual-memory
MEMORY_USER_ID=mazjieo
MEMORY_PROJECT=individual-memory

OLLAMA_BASE_URL=http://localhost:11434
# Use this when the app runs inside Docker and Ollama runs on the host:
# OLLAMA_BASE_URL=http://host.docker.internal:11434
MEMORY_LLM_PROVIDER=ollama
MEMORY_LLM_MODEL=qwen3.5:9b
MEMORY_LLM_TEMPERATURE=0.1
MEMORY_EMBEDDER_PROVIDER=ollama
MEMORY_EMBEDDER_MODEL=nomic-embed-text
MEMORY_EMBEDDING_DIMS=768

POSTGRES_HOST=localhost
# Use this when the app runs inside docker compose:
# POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=mem0
POSTGRES_PASSWORD=mem0
POSTGRES_DB=mem0
MEMORY_COLLECTION=coding_memory

MEMORY_DUPLICATE_SEARCH_LIMIT=10

MCP_TRANSPORT=stdio
MCP_HOST=127.0.0.1
MCP_PORT=8000
